# Backend
# SQLite 파일 경로 (상대경로는 backend 실행 위치 기준)
# 실제 DB 파일은 backend/data/ 아래에 생기며 git에 올리지 않음
DATABASE_URL=sqlite:///./data/meeting_action_tracker.db
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
# AI 호출 타임아웃(초). 넘기면 ai_status=failed
OPENROUTER_TIMEOUT_SECONDS=90
CORS_ORIGINS=http://localhost:3000

# Frontend (copy these into frontend/.env.local as needed)
NEXT_PUBLIC_API_URL=http://localhost:8000
